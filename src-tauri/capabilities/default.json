{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "drag:allow-start-drag",
    "process:allow-restart",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install"
  ]
}
