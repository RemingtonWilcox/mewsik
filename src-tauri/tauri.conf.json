{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mewsik",
  "version": "0.1.0",
  "identifier": "app.mewsik.desktop",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build && pnpm prepare:runtime"
  },
  "app": {
    "windows": [
      {
        "title": "mewsik",
        "width": 1200,
        "height": 800,
        "minWidth": 940,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../sidecar/dist/index.cjs": "sidecar/dist/index.cjs",
      "resources/bin/": "bin/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
