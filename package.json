{
  "name": "mewsik",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "prepare:runtime": "node scripts/prepare-runtime-resources.mjs",
    "sidecar:build": "mkdir -p sidecar/dist && pnpm exec esbuild sidecar/src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=sidecar/dist/index.cjs",
    "build": "pnpm sidecar:build && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "env PATH=\"${CARGO_HOME:-$HOME/.cargo}/bin:$PATH\" tauri",
    "tauri:dev": "pnpm sidecar:build && env PATH=\"${CARGO_HOME:-$HOME/.cargo}/bin:$PATH\" tauri dev",
    "tauri:build": "pnpm sidecar:build && env PATH=\"${CARGO_HOME:-$HOME/.cargo}/bin:$PATH\" tauri build",
    "release:macos": "bash scripts/macos-release.sh",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.0",
    "bits-ui": "^2.16.4",
    "esbuild": "^0.27.4",
    "ffmpeg-static": "5.3.0",
    "paneforge": "^1.0.2",
    "playwright": "^1.58.2",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.2",
    "svelte-sonner": "^1.1.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^7.3.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@crabnebula/tauri-plugin-drag": "2.1.0",
    "@lucide/svelte": "^1.7.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "bandcamp-fetch": "^3.0.0",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "soundcloud-downloader": "^1.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "youtubei.js": "^17.0.1"
  }
}
