{
  "name": "mewsik",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": "24.15.0",
    "pnpm": "10.11.0"
  },
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "version:check": "node scripts/check-version-consistency.mjs",
    "prepare:runtime": "node scripts/prepare-runtime-resources.mjs",
    "sidecar:build": "pnpm --filter mewsik-sidecar build",
    "build": "pnpm version:check && pnpm sidecar:build && vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "tauri:dev": "pnpm sidecar:build && tauri dev",
    "tauri:build": "pnpm sidecar:build && tauri build",
    "release:macos": "bash scripts/macos-release.sh",
    "release:preflight": "node scripts/prepare-release-config.mjs --check",
    "release:config": "node scripts/prepare-release-config.mjs",
    "release:verify-keypair": "node scripts/verify-release-keypair.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:discovery-snapshot": "node --test scripts/discovery-snapshot/generator.test.mjs",
    "test:release-policy": "node --test scripts/release-policy.test.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.69.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^25.5.0",
    "@webgpu/types": "^0.1.70",
    "bits-ui": "^2.16.4",
    "esbuild": "^0.28.1",
    "ffmpeg-static": "5.3.0",
    "paneforge": "^1.0.2",
    "playwright": "^1.58.2",
    "svelte": "^5.56.4",
    "svelte-check": "^4.4.2",
    "svelte-sonner": "^1.1.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^7.3.6"
  },
  "pnpm": {
    "overrides": {
      "cookie@<0.7.0": "0.7.2",
      "postcss@<8.5.10": "8.5.18",
      "undici": "7.28.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@crabnebula/tauri-plugin-drag": "2.1.0",
    "@lucide/svelte": "^1.7.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "clsx": "^2.1.1",
    "mode-watcher": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2"
  }
}
