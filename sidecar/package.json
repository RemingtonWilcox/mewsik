{
  "name": "mewsik-sidecar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "node -e \"require('fs').mkdirSync('dist',{recursive:true})\" && esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.cjs",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.cjs"
  },
  "dependencies": {
    "bandcamp-fetch": "^3.0.0",
    "soundcloud-fetch": "^1.2.0",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.5.0"
  }
}
